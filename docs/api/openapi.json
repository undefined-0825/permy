        "title": "DailyInfo"
      },
      "DiagnosisAnswer": {
        "properties": {
          "question_id": {
            "type": "string",
            "title": "Question Id"
          },
          "choice_id": {
            "type": "string",
            "title": "Choice Id"
          }
        },
        "type": "object",
        "required": [
          "question_id",
          "choice_id"
        ],
        "title": "DiagnosisAnswer"
      },
      "DiagnosisRequest": {
        "properties": {
          "answers": {
            "items": {
              "$ref": "#/components/schemas/DiagnosisAnswer"
            },
            "type": "array",
            "maxItems": 7,
            "minItems": 7,
            "title": "Answers"
          }
        },
        "type": "object",
        "required": [
          "answers"
        ],
        "title": "DiagnosisRequest"
      },
      "DiagnosisResponse": {
        "properties": {
          "persona_version": {
            "type": "integer",
            "title": "Persona Version"
          },
          "true_self_type": {
            "type": "string",
            "enum": [
              "Stability",
              "Independence",
              "Approval",
              "Realism",
              "Romance"
            ],
            "title": "True Self Type"
          },
          "night_self_type": {
            "type": "string",
            "enum": [
              "VisitPush",
              "Heal",
              "LittleDevil",
              "BigClient",
              "Balance"
            ],
            "title": "Night Self Type"
          },
          "persona_goal_primary": {
            "type": "string",
            "enum": [
              "next_visit",
              "relationship_keep",
              "long_term_growth",
              "firefighting",
              "special_distance"
            ],
            "title": "Persona Goal Primary"
          },
          "persona_goal_secondary": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Persona Goal Secondary"
          },
          "style_assertiveness": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Style Assertiveness"
          },
          "style_warmth": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Style Warmth"
          },
          "style_risk_guard": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Style Risk Guard"
          }
        },
        "type": "object",
        "required": [
          "persona_version",
          "true_self_type",
          "night_self_type",
          "persona_goal_primary",
          "style_assertiveness",
          "style_warmth",
          "style_risk_guard"
        ],
        "title": "DiagnosisResponse"
      },
      "Followup": {
        "properties": {
          "key": {
            "type": "string",
            "enum": [
              "relationship_type",
              "reply_length_pref",
              "ng_tags",
              "ng_free_phrases"
