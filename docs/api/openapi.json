            "default": "app_opened"
          },
          "app_version": {
            "type": "string",
            "title": "App Version"
          },
          "os": {
            "type": "string",
            "enum": [
              "android",
              "ios"
            ],
            "title": "Os"
          },
          "device_class": {
            "type": "string",
            "enum": [
              "phone",
              "tablet",
              "unknown"
            ],
            "title": "Device Class",
            "default": "unknown"
          }
        },
        "type": "object",
        "required": [
          "app_version",
          "os"
        ],
        "title": "AppOpenedEvent"
      },
      "AuthAnonymousResponse": {
        "properties": {
          "user_id": {
            "type": "string",
