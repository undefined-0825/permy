    "/api/v1/telemetry/events": {
      "post": {
        "summary": "Post Telemetry Events",
        "description": "Telemetryイベントを受信して保存（本文ゼロ厳守）\n\n- サーバでserver_time_utc, hour_bucket_utc, dow_utc, user_id_hashを付与\n- 会話本文/生成本文は絶対に含めない\n- event_data には各イベント固有のフィールドをJSON保存",
        "operationId": "post_telemetry_events_api_v1_telemetry_events_post",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
