          "candidate_id": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C"
            ],
            "title": "Candidate Id"
          }
        },
        "type": "object",
        "required": [
          "app_version",
          "os",
          "candidate_id"
        ],
        "title": "CandidateCopiedEvent"
      },
      "DailyInfo": {
        "properties": {
          "date": {
            "type": "string",
            "title": "Date"
          },
